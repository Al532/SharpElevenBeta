{
  "name": "sharp-eleven-app",
  "private": true,
  "version": "1.1.36",
  "scripts": {
    "dev": "vite",
    "dev:chart": "vite --config vite.chart.config.js",
    "test:chart": "node scripts/test-chart-module.mjs",
    "test:drill-wrappers": "node scripts/test-drill-root-wrappers.mjs",
    "typecheck": "tsc --noEmit",
    "prebuild": "node scripts/sync-public-files.mjs public",
    "build": "vite build",
    "prebuild:mobile": "node scripts/sync-public-files.mjs public",
    "build:mobile": "vite build --config vite.mobile.config.js",
    "mobile:install": "npm --prefix mobile install",
    "mobile:copy": "npm --prefix mobile run copy",
    "mobile:sync": "npm --prefix mobile run sync",
    "mobile:open:android": "npm --prefix mobile run open:android",
    "mobile:open:ios": "npm --prefix mobile run open:ios",
    "postbuild": "node scripts/sync-public-files.mjs build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vite": "^7.1.0",
    "vite-plugin-javascript-obfuscator": "^3.1.0"
  }
}
