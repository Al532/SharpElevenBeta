{
  "name": "sharp-eleven-app",
  "private": true,
  "type": "module",
  "version": "1.1.47",
  "dependencies": {
    "@capacitor/app": "^8.0.0"
  },
  "scripts": {
    "serve": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/serve-live-reload.ps1",
    "predev": "node scripts/sync-public-files.mjs root",
    "dev": "vite --config config/vite/vite.web.config.js",
    "predev:android:web": "node scripts/sync-public-files.mjs root",
    "dev:android:web": "vite --config config/vite/vite.web.config.js --host 0.0.0.0 --port 5173 --strictPort",
    "dev:typecheck": "tsc --noEmit --watch",
    "dev:chart": "vite --config config/vite/vite.chart.config.js",
    "test:chart": "node --import ./scripts/register-ts-source-loader.mjs scripts/test-chart-module.mjs",
    "test:drill-wrappers": "node --import ./scripts/register-ts-source-loader.mjs scripts/test-drill-root-wrappers.mjs",
    "typecheck": "tsc --noEmit",
    "prebuild": "node scripts/sync-public-files.mjs root",
    "build": "vite build --config config/vite/vite.web.config.js && node scripts/sync-public-files.mjs build",
    "prebuild:mobile": "node scripts/sync-public-files.mjs root",
    "build:mobile:app": "vite build --config config/vite/vite.mobile.config.js && node scripts/sync-public-files.mjs mobile",
    "build:mobile:assets": "node scripts/sync-mobile-shell-assets.mjs",
    "build:mobile:chart": "vite build --config config/vite/vite.mobile.chart.config.js",
    "build:mobile": "npm run build:mobile:app && npm run build:mobile:assets && npm run build:mobile:chart",
    "mobile:install": "npm --prefix mobile install",
    "mobile:copy": "npm --prefix mobile run copy",
    "mobile:sync": "npm --prefix mobile run sync",
    "mobile:run:android:live": "npm --prefix mobile run android:live",
    "mobile:open:android": "npm --prefix mobile run open:android",
    "mobile:open:ios": "npm --prefix mobile run open:ios",
    "preview": "vite preview --config config/vite/vite.web.config.js"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vite": "^7.1.0",
    "vite-plugin-javascript-obfuscator": "^3.1.0"
  }
}
