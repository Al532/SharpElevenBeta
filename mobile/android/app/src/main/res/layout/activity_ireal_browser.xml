<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ireal_browser_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F1E6"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/ireal_browser_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F7F1E6"
        android:elevation="0dp"
        android:gravity="center_vertical"
        android:minHeight="82dp"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="22dp"
        android:paddingEnd="16dp"
        android:paddingBottom="9dp">

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/ireal_browser_close_button"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_margin="0dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/ireal_browser_back"
            android:focusable="true"
            android:padding="0dp"
            android:scaleType="center"
            android:src="@drawable/ireal_browser_back_arrow"
            android:tint="#C49A68" />

        <TextView
            android:id="@+id/ireal_browser_banner_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:lineSpacingExtra="2dp"
            android:maxLines="3"
            android:text="@string/ireal_browser_title"
            android:textColor="#111111"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/ireal_browser_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:progressTint="#C49A68"
        android:progressBackgroundTint="#E6DFD1"
        android:max="100" />

    <WebView
        android:id="@+id/ireal_browser_webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</LinearLayout>
