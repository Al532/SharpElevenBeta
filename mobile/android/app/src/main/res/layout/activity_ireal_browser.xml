<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FB"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F4F7FB"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:minHeight="56dp"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingTop="8dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <Button
            android:id="@+id/ireal_browser_close_button"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:backgroundTint="#DCEEFF"
            android:minWidth="0dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:text="@string/ireal_browser_close"
            android:textAllCaps="false"
            android:textColor="#0D5FBA" />

        <TextView
            android:id="@+id/ireal_browser_banner_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="@string/ireal_browser_title"
            android:textColor="#0F1720"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/ireal_browser_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:max="100" />

    <WebView
        android:id="@+id/ireal_browser_webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</LinearLayout>
