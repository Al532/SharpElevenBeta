{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "strict": false,
    "lib": ["ES2022", "DOM"],
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "app.ts",
    "chart/**/*.ts",
    "chart-dev/**/*.ts",
    "core/**/*.ts",
    "core/types/**/*.d.ts",
    "features/**/*.ts",
    "config/**/*.ts"
  ]
}
